<?xml version="1.0" encoding="utf-8"?>
<!--
    Circular background for the pulse ring View.
    The color is set programmatically (dim or bright) depending on state.
    Default color is the dim pulse color; MainActivity overrides it for ActiveListening.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@color/colorPulseDim" />
</shape>
