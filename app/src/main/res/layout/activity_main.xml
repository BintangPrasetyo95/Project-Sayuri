<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for Sayuri — a single dark-themed screen.
    Requirements: 8.1, 8.3, 8.4, 8.5, 8.6, 8.8
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".MainActivity">

    <!--
        Pulse ring — a circular View that sits behind the mic button.
        Animated via pulse_dim (WakeWordListening) or pulse_bright (ActiveListening).
        Hidden in all other states.
        Requirements: 8.3, 8.4
    -->
    <View
        android:id="@+id/pulseRing"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_pulse_ring"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@id/micButton"
        app:layout_constraintEnd_toEndOf="@id/micButton"
        app:layout_constraintStart_toStartOf="@id/micButton"
        app:layout_constraintTop_toTopOf="@id/micButton" />

    <!--
        Mic FAB — centered on screen.
        Active state: colorMicActive background, mic icon.
        Muted/Idle state: colorMicMuted background, mic-off icon.
        Requirements: 2.7, 8.8
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/micButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/mic_button_description"
        android:src="@drawable/ic_mic"
        app:backgroundTint="@color/colorMicActive"
        app:fabSize="normal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/indicatorSpace"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45" />

    <!--
        Processing spinner — shown only in the Processing state.
        Sits just below the mic button, above the status text.
        Requirements: 8.5
    -->
    <ProgressBar
        android:id="@+id/processingSpinner"
        style="?android:attr/progressBarStyle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/colorSecondary"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/micButton"
        android:layout_marginTop="16dp" />

    <!--
        Speaking waveform indicator — a row of animated bars shown during Speaking state.
        Each bar is a thin rounded rectangle; they are animated via ObjectAnimator in code.
        Requirements: 8.6
    -->
    <LinearLayout
        android:id="@+id/speakingWaveform"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/micButton"
        android:layout_marginTop="16dp">

        <View
            android:id="@+id/waveBar1"
            android:layout_width="6dp"
            android:layout_height="16dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/waveBar2"
            android:layout_width="6dp"
            android:layout_height="28dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/waveBar3"
            android:layout_width="6dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/waveBar4"
            android:layout_width="6dp"
            android:layout_height="28dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_waveform_bar" />

        <View
            android:id="@+id/waveBar5"
            android:layout_width="6dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_waveform_bar" />

    </LinearLayout>

    <!--
        Invisible Space that reserves 64dp below the mic button so the status text
        stays at a stable position regardless of which indicator (spinner / waveform)
        is currently visible. Both processingSpinner and speakingWaveform overlap this
        space when shown; the Space itself is always present.
    -->
    <Space
        android:id="@+id/indicatorSpace"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/micButton"
        app:layout_constraintBottom_toTopOf="@id/statusText" />

    <!--
        Status text label — displayed below the mic button (and below the spinner/waveform).
        Maps each AssistantState to a human-readable string per Requirement 2.8.
        Requirements: 2.8, 8.3, 8.4, 8.5, 8.6, 8.7, 8.8
    -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:textColor="@color/colorStatusText"
        android:textSize="16sp"
        android:textStyle="normal"
        android:letterSpacing="0.05"
        tools:text="Listening for 'Sayuri'…"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/indicatorSpace" />

    <!--
        Subtitle text — shows the full TTS response text while Sayuri is speaking.
        Scrollable, multi-line, hidden in all other states.
    -->
    <ScrollView
        android:id="@+id/subtitleScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="72dp"
        android:visibility="gone"
        android:fadeScrollbars="true"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:fontFamily="sans-serif-light"
            tools:text="I'm doing great, tang! Ready to help you with anything. What's on your mind?" />

    </ScrollView>

    <!--
        Voice selector button — bottom-right corner.
        Tapping cycles through available TTS locales.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/voiceButton"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:textSize="12sp"
        android:textColor="@color/colorStatusText"
        android:text="🗣 EN-US"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
