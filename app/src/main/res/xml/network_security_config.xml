<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration (Requirements 12.1, 12.2).
    Disables cleartext (HTTP) traffic — all communication must use HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
